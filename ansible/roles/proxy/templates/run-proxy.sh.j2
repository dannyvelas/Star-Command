#!/bin/bash
# Auto-generated run script for Traefik reverse proxy.
# DO NOT EDIT — this file is managed by Ansible.

set -euo pipefail

CONTAINER_NAME="traefik"
IMAGE="{{ proxy_image }}"

# Stop and remove existing container if running
docker stop "$CONTAINER_NAME" 2>/dev/null || true
docker rm "$CONTAINER_NAME" 2>/dev/null || true

# Run container with the same configuration as Ansible
docker run -d \
  --name "$CONTAINER_NAME" \
  --restart unless-stopped \
  --read-only \
  -p {{ proxy_http_port }}:80 \
  -p {{ proxy_https_port }}:443 \
  -v {{ proxy_config_dir }}/traefik.yml:/etc/traefik/traefik.yml:ro \
  -v /var/run/docker.sock:/var/run/docker.sock:ro \
  --tmpfs /tmp \
  "$IMAGE"
